{
  "id": "creative-brief",
  "name": "综合创作简报",
  "description": "基于多条参考帖子的分析结果，生成一份综合创作简报",
  "version": "1.0.0",
  "target": "multi-post",
  "prompt": "你是一位资深内容策略总监。基于以下多条参考帖子的分析结果，生成一份综合创作简报。这份简报要能帮助创作者快速理解「这些参考为什么有效」以及「我可以怎么借鉴融合」。\n\n{{references}}\n\n{{requirements}}\n",
  "output_schema": {
    "type": "object",
    "properties": {
      "reference_summary": {
        "type": "string",
        "title": "参考精华总结",
        "description": "150字内参考精华总结"
      },
      "copy_direction": {
        "type": "string",
        "title": "文案方向建议",
        "description": "文案方向建议"
      },
      "visual_direction": {
        "type": "string",
        "title": "视觉方向建议",
        "description": "视觉方向建议"
      },
      "applicable_scenarios": {
        "type": "array",
        "items": { "type": "string" },
        "title": "适用场景",
        "description": "适用场景列表"
      },
      "adaptation_tips": {
        "type": "array",
        "items": { "type": "string" },
        "title": "改编建议",
        "description": "改编建议"
      }
    }
  }
}
