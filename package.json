{
  "name": "scopai",
  "version": "1.3.13",
  "private": true,
  "description": "AI-powered social media content analysis CLI tool",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:ui\"",
    "dev:api": "dotenv -e .env -- pnpm --filter @scopai/api dev",
    "dev:ui": "dotenv -e .env -- pnpm --filter @scopai/ui dev",
    "test": "pnpm -r test",
    "test:e2e": "node --test --test-concurrency=1 --experimental-strip-types 'test/e2e/**/*.test.ts'",
    "test:record": "npx tsx scripts/record-e2e-fixture.ts --platform xhs --query '上海美食' --limit 2 --output test-data/recorded/$(date +%Y-%m-%d)-xhs-shanghai",
    "release": "node scripts/release.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb",
      "esbuild"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
