{
  "id": "e2e_sentiment",
  "name": "E2E 情感分析",
  "description": "分析评论情感倾向",
  "version": "1.0.0",
  "target": "post",
  "prompt": "分析以下评论的情感倾向（positive/negative/neutral），返回 JSON：{ \"sentiment\": string, \"confidence\": number }",
  "output_schema": {
    "type": "object",
    "properties": {
      "sentiment": { "type": "string" },
      "confidence": { "type": "number" }
    }
  },
  "needs_media": false
}
