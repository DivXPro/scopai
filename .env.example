# 开发环境配置模板
# 复制为 .env 后按需修改

NODE_ENV=development

# API 服务器端口（开发环境默认 3001，生产 3000）
PORT=3001

# UI Vite 代理目标端口（需与 API 端口一致）
SCOPAI_API_PORT=3001

# 日志级别：debug | info | warn | error
ANALYZE_CLI_LOG_LEVEL=info

# Worker 并发数
ANALYZE_CLI_WORKERS=2

# Anthropic API 配置
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=claude-opus-4-5-20250514

# 数据库路径覆盖（可选）
# ANALYZE_CLI_DB_PATH=/custom/path/to/db.duckdb
